/* B1 Prevent Doctor Double Booking */

CREATE TRIGGER trg_PreventDoubleBooking
ON Appointments
AFTER INSERT
AS
BEGIN

IF EXISTS
(
SELECT 1
FROM Appointments a
JOIN inserted i
ON a.DoctorID=i.DoctorID
AND a.AppointmentDate=i.AppointmentDate
AND a.TimeSlot=i.TimeSlot
AND a.AppointmentID<>i.AppointmentID
AND a.Status IN ('Scheduled','Completed')
)

BEGIN
ROLLBACK;
THROW 50002,'Doctor already booked at this time slot',1;
END

END
GO



/* B2 Auto Generate Bill */

CREATE TRIGGER trg_GenerateBill
ON Appointments
AFTER UPDATE
AS
BEGIN

INSERT INTO Billing
(AppointmentID,ConsultationFee,MedicineCost,LabCost,InsuranceDiscount,GSTAmount,FinalAmount)

SELECT
i.AppointmentID,
d.ConsultationFee,
0,
0,
0,
0,
d.ConsultationFee
FROM inserted i
JOIN Doctors d ON i.DoctorID=d.DoctorID
WHERE i.Status='Completed';

END
GO



/* B3 Lab Abnormal FollowUp */

CREATE TRIGGER trg_LabFollowUp
ON LabOrders
AFTER INSERT,UPDATE
AS
BEGIN

UPDATE m
SET RequiresFollowUp=1
FROM MedicalRecords m
JOIN inserted i
ON m.AppointmentID=i.AppointmentID
WHERE i.IsAbnormal=1;

END
GO




