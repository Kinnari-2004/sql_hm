/* D1 Top 3 Doctors per Department */

SELECT *
FROM
(
SELECT
dep.DepartmentName,
doc.DoctorName,
SUM(b.FinalAmount) Revenue,
RANK() OVER(PARTITION BY dep.DepartmentID ORDER BY SUM(b.FinalAmount) DESC) RankNo
FROM Billing b
JOIN Appointments a ON b.AppointmentID=a.AppointmentID
JOIN Doctors doc ON a.DoctorID=doc.DoctorID
JOIN Departments dep ON doc.DepartmentID=dep.DepartmentID
GROUP BY dep.DepartmentName,doc.DoctorName,dep.DepartmentID
) t
WHERE RankNo<=3;



/* D2 Running Monthly Revenue */

SELECT
FORMAT(BillDate,'MMM yyyy') MonthYear,
SUM(FinalAmount) MonthlyRevenue,
SUM(SUM(FinalAmount)) OVER(ORDER BY YEAR(BillDate),MONTH(BillDate)) RunningTotal
FROM Billing
GROUP BY YEAR(BillDate),MONTH(BillDate),FORMAT(BillDate,'MMM yyyy')
ORDER BY YEAR(BillDate),MONTH(BillDate);




