/* =====================================================
   Hospital & Clinic Management System
   Complete SQL Server Script
   ===================================================== */

CREATE DATABASE HospitalDB;
GO

USE HospitalDB;
GO


/* =====================================================
   SECTION 1 — TABLES
   ===================================================== */

CREATE TABLE Departments(
DepartmentID INT IDENTITY PRIMARY KEY,
DepartmentName VARCHAR(100) NOT NULL
);

CREATE TABLE Doctors(
DoctorID INT IDENTITY PRIMARY KEY,
DoctorName VARCHAR(100),
Specialization VARCHAR(100),
ConsultationFee DECIMAL(10,2),
DepartmentID INT,
IsActive BIT DEFAULT 1,
FOREIGN KEY (DepartmentID) REFERENCES Departments(DepartmentID)
);

CREATE TABLE Patients(
PatientID INT IDENTITY PRIMARY KEY,
PatientName VARCHAR(100),
DOB DATE,
Phone VARCHAR(15),
Address VARCHAR(200),
InsurancePercent INT DEFAULT 0,
InsuranceMax DECIMAL(10,2)
);

CREATE TABLE Appointments(
AppointmentID INT IDENTITY PRIMARY KEY,
PatientID INT,
DoctorID INT,
AppointmentDate DATE,
TimeSlot VARCHAR(20),
Status VARCHAR(20) CHECK(Status IN ('Scheduled','Completed','Cancelled')),
FOREIGN KEY (PatientID) REFERENCES Patients(PatientID),
FOREIGN KEY (DoctorID) REFERENCES Doctors(DoctorID)
);

CREATE TABLE MedicalRecords(
RecordID INT IDENTITY PRIMARY KEY,
AppointmentID INT,
Diagnosis VARCHAR(200),
TreatmentPlan VARCHAR(200),
RequiresFollowUp BIT DEFAULT 0,
FOREIGN KEY (AppointmentID) REFERENCES Appointments(AppointmentID)
);

CREATE TABLE Medicines(
MedicineID INT IDENTITY PRIMARY KEY,
MedicineName VARCHAR(100),
Price DECIMAL(10,2)
);

CREATE TABLE Prescriptions(
PrescriptionID INT IDENTITY PRIMARY KEY,
RecordID INT,
MedicineID INT,
Dosage VARCHAR(50),
DurationDays INT,
Quantity INT,
FOREIGN KEY (RecordID) REFERENCES MedicalRecords(RecordID),
FOREIGN KEY (MedicineID) REFERENCES Medicines(MedicineID)
);

CREATE TABLE LabTests(
TestID INT IDENTITY PRIMARY KEY,
TestName VARCHAR(100),
Cost DECIMAL(10,2)
);

CREATE TABLE LabOrders(
LabOrderID INT IDENTITY PRIMARY KEY,
AppointmentID INT,
TestID INT,
Result VARCHAR(200),
IsAbnormal BIT DEFAULT 0,
FOREIGN KEY (AppointmentID) REFERENCES Appointments(AppointmentID),
FOREIGN KEY (TestID) REFERENCES LabTests(TestID)
);

CREATE TABLE Billing(
BillID INT IDENTITY PRIMARY KEY,
AppointmentID INT UNIQUE,
ConsultationFee DECIMAL(10,2),
MedicineCost DECIMAL(10,2),
LabCost DECIMAL(10,2),
InsuranceDiscount DECIMAL(10,2),
GSTAmount DECIMAL(10,2),
FinalAmount DECIMAL(10,2),
PaymentStatus VARCHAR(20) DEFAULT 'Pending',
BillDate DATETIME DEFAULT GETDATE(),
FOREIGN KEY (AppointmentID) REFERENCES Appointments(AppointmentID)
);



