/* A1 Monthly Department Report */

CREATE PROCEDURE sp_MonthlyDepartmentReport
@Month INT,
@Year INT
AS
BEGIN
SELECT
d.DepartmentName,
COUNT(a.AppointmentID) TotalAppointments,
COUNT(DISTINCT a.PatientID) UniquePatients,
SUM(doc.ConsultationFee) TotalConsultationRevenue
FROM Departments d
LEFT JOIN Doctors doc ON d.DepartmentID=doc.DepartmentID
LEFT JOIN Appointments a
ON doc.DoctorID=a.DoctorID
AND MONTH(a.AppointmentDate)=@Month
AND YEAR(a.AppointmentDate)=@Year
AND a.Status='Completed'
GROUP BY d.DepartmentName;
END
GO



/* A2 Patient Billing History */

CREATE PROCEDURE sp_PatientBillingHistory
@PatientID INT
AS
BEGIN

IF NOT EXISTS (SELECT 1 FROM Patients WHERE PatientID=@PatientID)
THROW 50001,'Patient ID not found',1;

SELECT
a.AppointmentDate,
d.DoctorName,
b.ConsultationFee,
b.MedicineCost,
b.LabCost,
b.InsuranceDiscount,
b.GSTAmount,
b.FinalAmount
FROM Billing b
JOIN Appointments a ON b.AppointmentID=a.AppointmentID
JOIN Doctors d ON a.DoctorID=d.DoctorID
WHERE a.PatientID=@PatientID;

SELECT SUM(FinalAmount) AS GrandTotal
FROM Billing b
JOIN Appointments a ON b.AppointmentID=a.AppointmentID
WHERE a.PatientID=@PatientID;

END
GO



/* A3 Doctor Performance Report */

CREATE PROCEDURE sp_DoctorPerformance
@MinAppointments INT
AS
BEGIN

SELECT
d.DoctorName,
COUNT(a.AppointmentID) TotalAppointments,
SUM(CASE WHEN a.Status='Completed' THEN 1 ELSE 0 END) CompletedAppointments,
SUM(b.FinalAmount) RevenueGenerated,
COUNT(DISTINCT m.Diagnosis) UniqueDiagnoses
FROM Doctors d
LEFT JOIN Appointments a ON d.DoctorID=a.DoctorID
LEFT JOIN Billing b ON a.AppointmentID=b.AppointmentID
LEFT JOIN MedicalRecords m ON a.AppointmentID=m.AppointmentID
GROUP BY d.DoctorName
HAVING COUNT(a.AppointmentID)>=@MinAppointments
ORDER BY RevenueGenerated DESC;

END
GO



/* A4 Medicines Never Prescribed */

CREATE PROCEDURE sp_MedicinesNeverPrescribed
AS
BEGIN

-- Method 1: Subquery

SELECT MedicineID,MedicineName
FROM Medicines
WHERE MedicineID NOT IN
(
SELECT MedicineID FROM Prescriptions
);

-- Method 2: SET operation

SELECT MedicineID,MedicineName
FROM Medicines

EXCEPT

SELECT m.MedicineID,m.MedicineName
FROM Medicines m
JOIN Prescriptions p
ON m.MedicineID=p.MedicineID;

END
GO



/* A5 Monthly Revenue vs Target */

CREATE PROCEDURE sp_RevenueTarget
AS
BEGIN

WITH RevenueData AS
(
SELECT
YEAR(BillDate) Yr,
MONTH(BillDate) Mn,
SUM(FinalAmount) Revenue
FROM Billing
GROUP BY YEAR(BillDate),MONTH(BillDate)
)

SELECT
Yr,
Mn,
Revenue,
CASE WHEN Revenue>=500000 THEN 'Yes' ELSE 'No' END AS TargetMet,
Revenue-500000 AS SurplusOrDeficit
FROM RevenueData;

END
GO




