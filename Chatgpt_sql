/* C1 Patient Age Function */

CREATE FUNCTION fn_GetPatientAge(@PatientID INT)
RETURNS INT
AS
BEGIN

DECLARE @age INT;

SELECT @age = DATEDIFF(YEAR,DOB,GETDATE())
FROM Patients
WHERE PatientID=@PatientID;

RETURN @age;

END
GO


SELECT PatientName,
dbo.fn_GetPatientAge(PatientID) AS Age
FROM Patients;



/* C2 Net Bill Calculator */

CREATE FUNCTION fn_CalculateNetBill
(
@Consultation DECIMAL(10,2),
@Medicine DECIMAL(10,2),
@Lab DECIMAL(10,2),
@InsurancePercent INT
)
RETURNS DECIMAL(10,2)
AS
BEGIN

DECLARE @Discount DECIMAL(10,2);
DECLARE @GST DECIMAL(10,2);
DECLARE @Final DECIMAL(10,2);

SET @Discount = (@Medicine + @Lab)*(@InsurancePercent/100.0);
SET @GST = (@Medicine*0.05)+(@Lab*0.12);

SET @Final = @Consultation + @Medicine + @Lab - @Discount + @GST;

RETURN @Final;

END
GO




