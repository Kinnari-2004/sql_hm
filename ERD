<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MediCare+ ER Diagram</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Fraunces:opsz,wght@9..144,300;9..144,600;9..144,700&family=DM+Sans:wght@300;400;500&display=swap');

  :root {
    --bg:        #0b0f1a;
    --surface:   #111827;
    --border:    #1e2d45;
    --accent1:   #38bdf8;   /* sky  */
    --accent2:   #34d399;   /* emerald */
    --accent3:   #f472b6;   /* pink */
    --accent4:   #fb923c;   /* orange */
    --accent5:   #a78bfa;   /* violet */
    --accent6:   #facc15;   /* yellow */
    --text:      #e2e8f0;
    --muted:     #64748b;
    --pk:        #38bdf8;
    --fk:        #fb923c;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    font-family: 'DM Sans', sans-serif;
    color: var(--text);
    min-height: 100vh;
    overflow-x: auto;
  }

  /* ── header ── */
  header {
    text-align: center;
    padding: 36px 24px 20px;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, #0d1422 0%, var(--bg) 100%);
  }
  header h1 {
    font-family: 'Fraunces', serif;
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #fff;
  }
  header p {
    font-size: 0.85rem;
    color: var(--muted);
    margin-top: 6px;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ── legend ── */
  .legend {
    display: flex;
    gap: 24px;
    justify-content: center;
    flex-wrap: wrap;
    padding: 14px 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    font-size: 0.75rem;
    font-family: 'DM Mono', monospace;
  }
  .legend-item { display: flex; align-items: center; gap: 7px; }
  .leg-box {
    width: 12px; height: 12px; border-radius: 3px;
  }
  .leg-pk  { background: var(--pk);  }
  .leg-fk  { background: var(--fk);  }
  .leg-col { background: var(--muted); }

  /* ── canvas wrapper ── */
  .canvas {
    position: relative;
    width: 2300px;
    min-height: 1620px;
    margin: 0 auto;
    padding: 40px;
  }

  /* ── svg connector layer ── */
  #connectors {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    overflow: visible;
  }

  /* ── entity table ── */
  .entity {
    position: absolute;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    min-width: 220px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    transition: box-shadow 0.2s;
  }
  .entity:hover {
    box-shadow: 0 12px 48px rgba(56,189,248,0.15);
    z-index: 100;
  }

  .entity-header {
    padding: 9px 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Fraunces', serif;
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    border-bottom: 1px solid var(--border);
  }
  .entity-header .dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .entity-body { padding: 6px 0; }

  .col-row {
    display: flex;
    align-items: center;
    padding: 3px 14px;
    gap: 8px;
    font-family: 'DM Mono', monospace;
    font-size: 0.72rem;
    line-height: 1.6;
    transition: background 0.15s;
  }
  .col-row:hover { background: rgba(255,255,255,0.03); }

  .col-badge {
    font-size: 0.6rem;
    padding: 1px 5px;
    border-radius: 3px;
    font-weight: 500;
    flex-shrink: 0;
    min-width: 26px;
    text-align: center;
  }
  .badge-pk  { background: rgba(56,189,248,0.18); color: var(--pk); }
  .badge-fk  { background: rgba(251,146,60,0.18);  color: var(--fk); }
  .badge-col { background: rgba(100,116,139,0.15); color: var(--muted); }

  .col-name  { color: var(--text); flex: 1; }
  .col-type  { color: var(--muted); font-size: 0.66rem; }

  /* ── connector lines (SVG) ── */
  .conn { stroke-width: 1.5; fill: none; }
  .conn-1n { stroke: var(--accent2); stroke-dasharray: none; }
  .conn-mn { stroke: var(--accent3); stroke-dasharray: 5,3; }
  .conn-11 { stroke: var(--accent1); stroke-dasharray: none; }

  /* cardinality text */
  .card-label {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    fill: #94a3b8;
  }

  /* section label */
  .section-label {
    position: absolute;
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: rgba(17,24,39,0.8);
  }
</style>
</head>
<body>

<header>
  <h1>MediCare+ Hospital &amp; Clinic Management System</h1>
  <p>Entity-Relationship Diagram · SQL Server · 12 Tables</p>
</header>

<div class="legend">
