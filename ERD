      <div class="col-row"><span class="col-badge badge-col">  </span><span class="col-name">FinalAmount</span><span class="col-type">DECIMAL(10,2)</span></div>
      <div class="col-row"><span class="col-badge badge-col">  </span><span class="col-name">PaymentStatus</span><span class="col-type">NVARCHAR(15)</span></div>
      <div class="col-row"><span class="col-badge badge-col">  </span><span class="col-name">BilledOn</span><span class="col-type">DATETIME</span></div>
    </div>
  </div>

</div><!-- end canvas -->

<script>
// ──────────────────────────────────────────────
// Draw SVG connectors between entities
// ──────────────────────────────────────────────
function getCenter(el) {
  const r = el.getBoundingClientRect();
  const cr = document.getElementById('canvas').getBoundingClientRect();
  return {
    x: r.left - cr.left + r.width  / 2,
    y: r.top  - cr.top  + r.height / 2,
    l: r.left - cr.left,
    r: r.right - cr.left,
    t: r.top  - cr.top,
    b: r.bottom - cr.top,
    w: r.width,
    h: r.height
  };
}

function midRight(el) { const c=getCenter(el); return {x:c.r, y:c.y}; }
function midLeft(el)  { const c=getCenter(el); return {x:c.l, y:c.y}; }
function midBot(el)   { const c=getCenter(el); return {x:c.x, y:c.b}; }
function midTop(el)   { const c=getCenter(el); return {x:c.x, y:c.t}; }

function bezier(x1,y1,x2,y2) {
  const dx = Math.abs(x2-x1)*0.5;
  return `M${x1},${y1} C${x1+dx},${y1} ${x2-dx},${y2} ${x2},${y2}`;
}
function straight(x1,y1,x2,y2) {
  return `M${x1},${y1} L${x2},${y2}`;
}
function elbow(x1,y1,x2,y2) {
  const mx = (x1+x2)/2;
  return `M${x1},${y1} L${mx},${y1} L${mx},${y2} L${x2},${y2}`;
}

function makePath(d, cls, extra='') {
  const p = document.createElementNS('http://www.w3.org/2000/svg','path');
  p.setAttribute('d', d);
  p.setAttribute('class', 'conn '+cls);
  if (extra) p.setAttribute('style', extra);
  return p;
}

function makeText(x, y, txt) {
  const t = document.createElementNS('http://www.w3.org/2000/svg','text');
  t.setAttribute('x', x); t.setAttribute('y', y);
  t.setAttribute('class','card-label');
  t.setAttribute('text-anchor','middle');
  t.textContent = txt;
  return t;
}

// marker arrowhead
function addMarker(svg, id, color) {
  const defs = svg.querySelector('defs') || svg.insertBefore(
    document.createElementNS('http://www.w3.org/2000/svg','defs'),
    svg.firstChild
  );
  const m = document.createElementNS('http://www.w3.org/2000/svg','marker');
  m.setAttribute('id', id);
  m.setAttribute('markerWidth','8');
  m.setAttribute('markerHeight','8');
  m.setAttribute('refX','6');
  m.setAttribute('refY','3');
  m.setAttribute('orient','auto');
  const poly = document.createElementNS('http://www.w3.org/2000/svg','path');
  poly.setAttribute('d','M0,0 L0,6 L8,3 z');
  poly.setAttribute('fill', color);
  m.appendChild(poly);
  defs.appendChild(m);
}

window.addEventListener('load', () => {
  const svg = document.getElementById('connectors');
  const canvas = document.getElementById('canvas');
  svg.setAttribute('width',  canvas.scrollWidth);
  svg.setAttribute('height', canvas.scrollHeight);

  addMarker(svg,'arrow-green','#34d399');
  addMarker(svg,'arrow-pink', '#f472b6');
  addMarker(svg,'arrow-sky',  '#38bdf8');
  addMarker(svg,'arrow-orange','#fb923c');

  const E = id => document.getElementById(id);

  // helper — draw a line from right-edge of A to left-edge of B, with cardinality labels
  function connect(fromId, toId, cls, fromCard, toCard, style='bezier') {
    const a = E(fromId), b = E(toId);
    const ca = getCenter(a), cb = getCenter(b);
    let p1, p2, d;

    // choose exit/entry sides based on relative position
    if (Math.abs(ca.x - cb.x) > Math.abs(ca.y - cb.y)) {
      // horizontal dominant
      if (ca.x < cb.x) { p1={x:ca.r,y:ca.y}; p2={x:cb.l,y:cb.y}; }
      else              { p1={x:ca.l,y:ca.y}; p2={x:cb.r,y:cb.y}; }
    } else {
      // vertical dominant
      if (ca.y < cb.y) { p1={x:ca.x,y:ca.b}; p2={x:cb.x,y:cb.t}; }
      else             { p1={x:ca.x,y:ca.t}; p2={x:cb.x,y:cb.b}; }
    }

    d = bezier(p1.x,p1.y,p2.x,p2.y);

    const color = cls==='conn-1n'?'#34d399': cls==='conn-mn'?'#f472b6':'#38bdf8';
    const path = makePath(d, cls, `marker-end:url(#arrow-${
      cls==='conn-1n'?'green':cls==='conn-mn'?'pink':'sky'})`);
    svg.appendChild(path);

    // cardinality labels
    const ox=10, oy=-8;
    svg.appendChild(makeText(p1.x+ox, p1.y+oy, fromCard));
    svg.appendChild(makeText(p2.x-ox, p2.y+oy, toCard));
  }

  // ── Departments ↔ Doctors (1:N — a dept has many doctors)
  connect('eDepartments','eDoctors',   'conn-1n','1','N');
  // ── Departments.HeadDoctorID → Doctors (1:1)
  // (drawn as a short curve back — skip to keep clean)

  // ── Doctors → DoctorSchedules (1:N)
  connect('eDoctors','eDoctorSchedules','conn-1n','1','N');

  // ── Patients → InsurancePolicies (1:N)
  connect('ePatients','eInsurance',    'conn-1n','1','N');

  // ── Patients → Appointments (1:N)
  connect('ePatients','eAppointments', 'conn-1n','1','N');

  // ── Doctors → Appointments (1:N)
  connect('eDoctors','eAppointments',  'conn-1n','1','N');

  // ── Appointments → MedicalRecords (1:1)
  connect('eAppointments','eMedicalRecords','conn-11','1','1');

  // ── Appointments → Prescriptions (1:N)
  connect('eAppointments','ePrescriptions','conn-1n','1','N');

  // ── Medicines → Prescriptions (1:N)
  connect('eMedicines','ePrescriptions','conn-1n','1','N');

  // ── Appointments → LabOrders (1:N)
  connect('eAppointments','eLabOrders','conn-1n','1','N');

  // ── LabTests → LabOrders (1:N)
  connect('eLabTests','eLabOrders',   'conn-1n','1','N');

  // ── Appointments → Billing (1:1)
  connect('eAppointments','eBilling', 'conn-11','1','1');
});
</script>

