    width: 2100px;
    height: 1500px;
    margin: 0 auto;
  }
  svg#lines {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    overflow: visible;
  }

  /* ── Table card ── */
  .tbl {
    position: absolute;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 3px 10px rgba(0,0,0,0.25);
