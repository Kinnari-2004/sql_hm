<script>
// ── Draw crow's foot SVG connectors ──
const svg = document.getElementById('lines');
const canvas = document.getElementById('canvas');

function box(id) {
  const el = document.getElementById(id);
  const cr = canvas.getBoundingClientRect();
  const r  = el.getBoundingClientRect();
  return {
    l: r.left - cr.left, r: r.right  - cr.left,
    t: r.top  - cr.top,  b: r.bottom - cr.top,
    cx: (r.left+r.right)/2  - cr.left,
    cy: (r.top+r.bottom)/2  - cr.top,
    w: r.width, h: r.height
  };
}

function line(x1,y1,x2,y2,dash=false){
  const p = document.createElementNS('http://www.w3.org/2000/svg','line');
  p.setAttribute('x1',x1); p.setAttribute('y1',y1);
  p.setAttribute('x2',x2); p.setAttribute('y2',y2);
  p.setAttribute('stroke','#444');
  p.setAttribute('stroke-width','1.5');
  if(dash) p.setAttribute('stroke-dasharray','6,3');
  svg.appendChild(p);
}
function path(d,dash=false){
  const p = document.createElementNS('http://www.w3.org/2000/svg','path');
  p.setAttribute('d',d);
  p.setAttribute('stroke','#444');
  p.setAttribute('stroke-width','1.5');
  p.setAttribute('fill','none');
  if(dash) p.setAttribute('stroke-dasharray','6,3');
  svg.appendChild(p);
}
// One marker (crow's foot = 3 lines; single = | ; 1 = small tick)
function crowFoot(x, y, dir){ // dir: 'l','r','t','b'
  const s=10;
  if(dir==='r'){
    line(x,y,x+s,y-s); line(x,y,x+s,y+s); line(x,y,x+s,y);
    line(x+s,y-s/2,x+s,y+s/2); // mandatory line
  } else if(dir==='l'){
    line(x,y,x-s,y-s); line(x,y,x-s,y+s); line(x,y,x-s,y);
    line(x-s,y-s/2,x-s,y+s/2);
  } else if(dir==='b'){
    line(x,y,x-s,y+s); line(x,y,x+s,y+s); line(x,y,x+s,y);
    line(x-s/2,y+s,x+s/2,y+s);
  } else if(dir==='t'){
    line(x,y,x-s,y-s); line(x,y,x+s,y-s); line(x,y,x-s,y);
    line(x-s/2,y-s,x+s/2,y-s);
  }
}
function tick(x, y, dir){ // "1" side marker
  const s=8;
  if(dir==='r'){ line(x+2,y-s,x+2,y+s); }
  else if(dir==='l'){ line(x-2,y-s,x-2,y+s); }
  else if(dir==='b'){ line(x-s,y+2,x+s,y+2); }
  else if(dir==='t'){ line(x-s,y-2,x+s,y-2); }
}

// Bezier connecting two points (horizontal dominant)
function connect(ax, ay, bx, by, dash=false){
  const dx = Math.abs(bx-ax)*0.45;
  path(`M${ax},${ay} C${ax+Math.sign(bx-ax)*dx},${ay} ${bx-Math.sign(bx-ax)*dx},${by} ${bx},${by}`, dash);
}
// Elbow connector
function elbow(ax,ay,bx,by,dash=false){
  const mx=(ax+bx)/2;
  path(`M${ax},${ay} L${mx},${ay} L${mx},${by} L${bx},${by}`,dash);
}

window.addEventListener('load', () => {
  svg.setAttribute('width', canvas.scrollWidth);
  svg.setAttribute('height', canvas.scrollHeight);

  const dep  = box('tDepartment');
  const doc  = box('tDoctors');
  const tt   = box('tTimeTable');
  const pat  = box('tPatients');
  const ins  = box('tInsurance');
  const pi   = box('tPatIns');
  const appt = box('tAppointments');
  const diag = box('tDiagnosis');
  const pres = box('tPrescriptions');
  const pm   = box('tPresMed');
  const med  = box('tMedicines');
  const lt   = box('tLabTests');
  const lo   = box('tLabOrders');
  const bill = box('tBills');

  // Department — Doctors  (1:N)
  connect(dep.r, dep.cy, doc.l, doc.cy);
  tick(dep.r, dep.cy, 'r');
  crowFoot(doc.l, doc.cy, 'l');

  // Doctors — Time_Table  (1:N)
  connect(doc.r, doc.cy, tt.l, tt.cy);
  tick(doc.r, doc.cy, 'r');
  crowFoot(tt.l, tt.cy, 'l');

  // Doctors.head_doctor → Department (1:1 self-ref — loop above)
  elbow(doc.cx, doc.t, dep.cx, dep.t);

  // Doctors — Appointments  (1:N)
  connect(doc.b, doc.cx, appt.t, appt.cx);
  tick(doc.b, doc.cx, 'b');
  crowFoot(appt.t, appt.cx, 't');

  // Patients — Appointments  (1:N)
  connect(pat.r, pat.cy, appt.l, appt.cy);
  tick(pat.r, pat.cy, 'r');
  crowFoot(appt.l, appt.cy, 'l');

  // Insurance — Patients_Insurance  (1:N)
  connect(ins.b, ins.cx, pi.t, pi.cx);
  tick(ins.b, ins.cx, 'b');
  crowFoot(pi.t, pi.cx, 't');

  // Patients — Patients_Insurance  (1:N)
  elbow(pat.l, pat.cy, pi.r, pi.cy);
  tick(pat.l, pat.cy, 'l');
  crowFoot(pi.r, pi.cy, 'r');

  // Appointments — Diagnosis  (1:1)
  connect(appt.r, appt.cy, diag.l, diag.cy);
  tick(appt.r, appt.cy, 'r');
  tick(diag.l, diag.cy, 'l');

  // Appointments — Prescriptions  (1:1)
  connect(appt.b, appt.cx, pres.t, pres.cx);
  tick(appt.b, appt.cx, 'b');
  tick(pres.t, pres.cx, 't');

  // Prescriptions — Prescription_Medicines  (1:N)
  connect(pres.r, pres.cy, pm.l, pm.cy);
  tick(pres.r, pres.cy, 'r');
  crowFoot(pm.l, pm.cy, 'l');

  // Medicines — Prescription_Medicines  (1:N)
  connect(med.l, med.cy, pm.r, pm.cy);
  tick(med.l, med.cy, 'l');
  crowFoot(pm.r, pm.cy, 'r');

  // Appointments — Lab_Orders  (1:N)
  connect(appt.r, appt.b-40, lo.l, lo.cy);
  tick(appt.r, appt.b-40, 'r');
  crowFoot(lo.l, lo.cy, 'l');

  // Lab_Tests — Lab_Orders  (1:N)
  connect(lt.l, lt.cy, lo.r, lo.cy);
  tick(lt.l, lt.cy, 'l');
  crowFoot(lo.r, lo.cy, 'r');

  // Appointments — Bills  (1:1)
  elbow(appt.b, appt.l+30, bill.t, bill.cx);
  tick(appt.b, appt.l+30, 'b');
  tick(bill.t, bill.cx, 't');

  // Patients — Bills  (1:N)
  elbow(pat.b, pat.cx, bill.l, bill.cy);
  tick(pat.b, pat.cx, 'b');
  crowFoot(bill.l, bill.cy, 'l');
});
</script>
