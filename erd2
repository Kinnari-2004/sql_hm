    font-weight: 700;
    font-size: 13px;
    color: #fff;
    text-align: center;
  }
  .tbl-body {
    background: #fff;
    border: 1.5px solid #aab;
    border-top: none;
  }
  .tbl-row {
    display: flex;
    justify-content: space-between;
    padding: 3px 10px;
    border-bottom: 1px solid #e8eaf0;
    font-size: 11.5px;
    gap: 16px;
  }
  .tbl-row:last-child { border-bottom: none; }
  .col-name { color: #1a1a2e; font-weight: 500; }
  .col-type { color: #555; font-size: 10.5px; white-space: nowrap; }

