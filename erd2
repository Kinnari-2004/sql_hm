    padding: 8px 20px;
    background: #2c3e6b;
    color: #cdd;
    font-size: 11px;
    justify-content: center;
  }
  .legend span { display: flex; align-items: center; gap: 6px; }
  .leg-line {
    display: inline-block; width: 28px; height: 2px;
  }
</style>
</head>
