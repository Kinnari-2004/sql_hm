-- ============================================================
-- SECTION 02 — CREATE TABLES
-- ============================================================

-- 1. kv_Department
CREATE TABLE kv_Department (
    dept_id     INT            IDENTITY(1,1) PRIMARY KEY,
    dept_name   NVARCHAR(100)  NOT NULL UNIQUE,
    head_doctor INT            NULL
);
GO

-- 2. kv_Doctors
CREATE TABLE kv_Doctors (
    doctor_id      INT            IDENTITY(1,1) PRIMARY KEY,
    doctor_name    NVARCHAR(100)  NOT NULL,
    email          NVARCHAR(100)  NOT NULL UNIQUE,
    date_of_birth  DATE           NOT NULL,
    address        NVARCHAR(255)  NULL,
    phone_number   NVARCHAR(15)   NULL,
    specialization NVARCHAR(100)  NOT NULL,
    fees           DECIMAL(10,2)  NOT NULL CHECK (fees >= 0),
    dept_id        INT            NOT NULL REFERENCES kv_Department(dept_id),
    is_active      BIT            NOT NULL DEFAULT 1
);
GO

ALTER TABLE kv_Department
    ADD CONSTRAINT FK_kv_Dept_HeadDoctor
    FOREIGN KEY (head_doctor) REFERENCES kv_Doctors(doctor_id);
GO

-- 3. kv_Time_Table
CREATE TABLE kv_Time_Table (
    timetable_id INT           IDENTITY(1,1) PRIMARY KEY,
    doctor_id    INT           NOT NULL REFERENCES kv_Doctors(doctor_id),
    day_of_week  NVARCHAR(10)  NOT NULL
                     CHECK (day_of_week IN ('Monday','Tuesday','Wednesday',
                                            'Thursday','Friday','Saturday','Sunday')),
    start_time   TIME          NOT NULL,
    end_time     TIME          NOT NULL,
    CONSTRAINT CHK_kv_TT_Times     CHECK (end_time > start_time),
    CONSTRAINT UQ_kv_TT_DoctorSlot UNIQUE (doctor_id, day_of_week, start_time)
);
GO

-- 4. kv_Patients
CREATE TABLE kv_Patients (
    patient_id    INT            IDENTITY(1,1) PRIMARY KEY,
    patient_name  NVARCHAR(100)  NOT NULL,
    email         NVARCHAR(100)  NOT NULL UNIQUE,
    phone         NVARCHAR(15)   NULL,
    date_of_birth DATE           NOT NULL,
    gender        NVARCHAR(10)   CHECK (gender IN ('Male','Female','Other')),
    address       NVARCHAR(255)  NULL,
    registered_on DATE           NOT NULL DEFAULT CAST(GETDATE() AS DATE)
);
GO

-- 5. kv_Insurance
CREATE TABLE kv_Insurance (
    insurance_id     INT            IDENTITY(1,1) PRIMARY KEY,
    provider_name    NVARCHAR(100)  NOT NULL,
    coverage_percent DECIMAL(5,2)   NOT NULL CHECK (coverage_percent BETWEEN 0 AND 100),
    yearly_maximum   DECIMAL(12,2)  NOT NULL CHECK (yearly_maximum >= 0),
    coverage_details NVARCHAR(500)  NULL
);
GO

-- 6. kv_Patients_Insurance
CREATE TABLE kv_Patients_Insurance (
    insurance_id  INT          NOT NULL REFERENCES kv_Insurance(insurance_id),
    patient_id    INT          NOT NULL REFERENCES kv_Patients(patient_id),
    policy_number NVARCHAR(50) NOT NULL UNIQUE,
    valid_from    DATE         NOT NULL,
    valid_to      DATE         NOT NULL,
    CONSTRAINT PK_kv_PatIns    PRIMARY KEY (insurance_id, patient_id),
    CONSTRAINT CHK_kv_PI_Dates CHECK (valid_to >= valid_from)
);
GO

-- 7. kv_Appointments
CREATE TABLE kv_Appointments (
    appointment_id INT           IDENTITY(1,1) PRIMARY KEY,
    doctor_id      INT           NOT NULL REFERENCES kv_Doctors(doctor_id),
    patient_id     INT           NOT NULL REFERENCES kv_Patients(patient_id),
    appt_date      DATE          NOT NULL,
    time_slot      NVARCHAR(20)  NOT NULL,
    status         NVARCHAR(15)  NOT NULL DEFAULT 'Scheduled'
                       CHECK (status IN ('Scheduled','Completed','Cancelled')),
    notes          NVARCHAR(500) NULL,
    CONSTRAINT UQ_kv_Doctor_Slot UNIQUE (doctor_id, appt_date, time_slot)
);
GO

-- 8. kv_Diagnosis
CREATE TABLE kv_Diagnosis (
    diagnosis_id      INT            IDENTITY(1,1) PRIMARY KEY,
    appointment_id    INT            NOT NULL UNIQUE REFERENCES kv_Appointments(appointment_id),
    doctor_id         INT            NOT NULL REFERENCES kv_Doctors(doctor_id),
    patient_id        INT            NOT NULL REFERENCES kv_Patients(patient_id),
    diagnosis_details NVARCHAR(1000) NOT NULL,
    treatment_plan    NVARCHAR(1000) NULL,
    requires_followup BIT            NOT NULL DEFAULT 0,
    diagnosis_date    DATE           NOT NULL DEFAULT CAST(GETDATE() AS DATE)
);
GO

-- 9. kv_Medicines
CREATE TABLE kv_Medicines (
    medicine_id   INT            IDENTITY(1,1) PRIMARY KEY,
    medicine_name NVARCHAR(100)  NOT NULL UNIQUE,
    category      NVARCHAR(50)   NULL,
    price         DECIMAL(10,2)  NOT NULL CHECK (price >= 0),
    exp_date      DATE           NOT NULL
);
GO

-- 10. kv_Prescriptions
CREATE TABLE kv_Prescriptions (
    prescription_id INT  IDENTITY(1,1) PRIMARY KEY,
    appointment_id  INT  NOT NULL UNIQUE REFERENCES kv_Appointments(appointment_id),
    patient_id      INT  NOT NULL REFERENCES kv_Patients(patient_id),
    doctor_id       INT  NOT NULL REFERENCES kv_Doctors(doctor_id),
    pres_date       DATE NOT NULL DEFAULT CAST(GETDATE() AS DATE)
);
GO

-- 11. kv_Prescription_Medicines
CREATE TABLE kv_Prescription_Medicines (
    prescription_id INT          NOT NULL REFERENCES kv_Prescriptions(prescription_id),
    medicine_id     INT          NOT NULL REFERENCES kv_Medicines(medicine_id),
    dosage          NVARCHAR(50) NOT NULL,
    duration_days   INT          NOT NULL CHECK (duration_days > 0),
    quantity        INT          NOT NULL CHECK (quantity > 0),
    CONSTRAINT PK_kv_PresMed PRIMARY KEY (prescription_id, medicine_id)
);
GO

-- 12. kv_Lab_Tests
CREATE TABLE kv_Lab_Tests (
    lab_test_id INT            IDENTITY(1,1) PRIMARY KEY,
    test_name   NVARCHAR(100)  NOT NULL UNIQUE,
    description NVARCHAR(500)  NULL,
    price       DECIMAL(10,2)  NOT NULL CHECK (price >= 0)
);
GO

-- 13. kv_Lab_Orders
CREATE TABLE kv_Lab_Orders (
    lab_order_id   INT            IDENTITY(1,1) PRIMARY KEY,
    appointment_id INT            NOT NULL REFERENCES kv_Appointments(appointment_id),
    lab_test_id    INT            NOT NULL REFERENCES kv_Lab_Tests(lab_test_id),
    ordered_on     DATETIME       NOT NULL DEFAULT GETDATE(),
    result_value   NVARCHAR(200)  NULL,
    result_date    DATE           NULL,
    is_abnormal    BIT            NOT NULL DEFAULT 0,
    CONSTRAINT UQ_kv_LabOrder UNIQUE (appointment_id, lab_test_id)
);
GO

-- 14. kv_Bills
CREATE TABLE kv_Bills (
    bill_id            INT            IDENTITY(1,1) PRIMARY KEY,
    appointment_id     INT            NOT NULL UNIQUE REFERENCES kv_Appointments(appointment_id),
    patient_id         INT            NOT NULL REFERENCES kv_Patients(patient_id),
    consult_charge     DECIMAL(10,2)  NOT NULL DEFAULT 0,
    medicine_charge    DECIMAL(10,2)  NOT NULL DEFAULT 0,
    lab_charge         DECIMAL(10,2)  NOT NULL DEFAULT 0,
    insurance_discount DECIMAL(10,2)  NOT NULL DEFAULT 0,
    gst_on_consult     DECIMAL(10,2)  NOT NULL DEFAULT 0,
    gst_on_medicine    DECIMAL(10,2)  NOT NULL DEFAULT 0,
    gst_on_lab         DECIMAL(10,2)  NOT NULL DEFAULT 0,
    payable_amount     DECIMAL(10,2)  NOT NULL DEFAULT 0,
    payment_status     NVARCHAR(15)   NOT NULL DEFAULT 'Unpaid'
                           CHECK (payment_status IN ('Unpaid','Paid','Partially Paid')),
    billed_on          DATETIME       NOT NULL DEFAULT GETDATE()
);
GO

