-- D1: Top 3 Doctors per Department by Revenue
WITH doctor_revenue AS (
    SELECT
        dep.dept_name, d.doctor_name,
        SUM(b.payable_amount) AS total_revenue,
        DENSE_RANK() OVER (
            PARTITION BY dep.dept_id
            ORDER BY SUM(b.payable_amount) DESC
        ) AS revenue_rank
    FROM kv_Doctors      d
    JOIN kv_Department   dep ON dep.dept_id      = d.dept_id
    JOIN kv_Appointments a   ON a.doctor_id      = d.doctor_id AND a.status = 'Completed'
    JOIN kv_Bills        b   ON b.appointment_id = a.appointment_id
    GROUP BY dep.dept_id, dep.dept_name, d.doctor_id, d.doctor_name
)
SELECT dept_name, doctor_name, total_revenue, revenue_rank
FROM   doctor_revenue
WHERE  revenue_rank <= 3
ORDER  BY dept_name, revenue_rank;
GO

-- D2: Running Monthly Revenue Total
SELECT
    FORMAT(DATEFROMPARTS(bill_year, bill_month, 1), 'MMM yyyy') AS month_year,
    monthly_revenue,
    SUM(monthly_revenue) OVER (
        ORDER BY bill_year, bill_month
        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
    ) AS cumulative_revenue
FROM (
    SELECT YEAR(billed_on)      AS bill_year,
           MONTH(billed_on)     AS bill_month,
           SUM(payable_amount)  AS monthly_revenue
    FROM kv_Bills
    GROUP BY YEAR(billed_on), MONTH(billed_on)
) sub
ORDER BY bill_year, bill_month;
GO

