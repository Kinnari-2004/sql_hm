-- B1: Prevent Doctor Double Booking
CREATE OR ALTER TRIGGER dbo.trg_kv_PreventDoctorDoubleBooking
ON kv_Appointments
AFTER INSERT
AS
BEGIN
    SET NOCOUNT ON;
    IF EXISTS (
        SELECT 1
        FROM inserted i
        JOIN kv_Appointments a
            ON  a.doctor_id      = i.doctor_id
            AND a.appt_date      = i.appt_date
            AND a.time_slot      = i.time_slot
            AND a.status         IN ('Scheduled','Completed')
            AND a.appointment_id <> i.appointment_id
    )
    BEGIN
        ROLLBACK TRANSACTION;
        THROW 50100, 'Double-booking error: Doctor already has an appointment at this date and time slot.', 1;
    END;
END;
GO

-- B2: Auto Generate Bill on Completion (set-based, no cursor)
CREATE OR ALTER TRIGGER dbo.trg_kv_AutoGenerateBillOnCompletion
ON kv_Appointments
AFTER UPDATE
AS
BEGIN
    SET NOCOUNT ON;

    IF NOT EXISTS (
        SELECT 1 FROM inserted i
        JOIN deleted d ON d.appointment_id = i.appointment_id
        WHERE i.status = 'Completed' AND d.status <> 'Completed'
    ) RETURN;

    BEGIN TRY
        -- Error if bill already exists
        IF EXISTS (
            SELECT 1 FROM inserted i
            JOIN deleted  d ON d.appointment_id = i.appointment_id
            JOIN kv_Bills b ON b.appointment_id = i.appointment_id
            WHERE i.status = 'Completed' AND d.status <> 'Completed'
        )
        THROW 50200, 'Bill already exists for one or more of these appointments.', 1;

        -- CTE chain to calculate everything set-based
        ;WITH NewlyCompleted AS (
            SELECT i.appointment_id, i.patient_id, i.doctor_id, i.appt_date
            FROM inserted i
            JOIN deleted d ON d.appointment_id = i.appointment_id
            WHERE i.status = 'Completed' AND d.status <> 'Completed'
        ),
        MedCost AS (
            SELECT pr.appointment_id, SUM(m.price * pm.quantity) AS med_cost
            FROM kv_Prescriptions pr
            JOIN kv_Prescription_Medicines pm ON pm.prescription_id = pr.prescription_id
            JOIN kv_Medicines m               ON m.medicine_id      = pm.medicine_id
            WHERE pr.appointment_id IN (SELECT appointment_id FROM NewlyCompleted)
            GROUP BY pr.appointment_id
        ),
        LabCost AS (
            SELECT lo.appointment_id, SUM(lt.price) AS lab_cost
            FROM kv_Lab_Orders lo
            JOIN kv_Lab_Tests  lt ON lt.lab_test_id = lo.lab_test_id
            WHERE lo.appointment_id IN (SELECT appointment_id FROM NewlyCompleted)
            GROUP BY lo.appointment_id
        ),
        InsPct AS (
            SELECT pi2.patient_id, ins.coverage_percent, nc.appt_date
            FROM kv_Patients_Insurance pi2
            JOIN kv_Insurance   ins ON ins.insurance_id = pi2.insurance_id
            JOIN NewlyCompleted  nc  ON nc.patient_id   = pi2.patient_id
            WHERE pi2.valid_from <= nc.appt_date AND pi2.valid_to >= nc.appt_date
        ),
        Calculated AS (
            SELECT
                nc.appointment_id,
                nc.patient_id,
                nc.appt_date,
                d.fees                                                  AS consult_charge,
                ISNULL(mc.med_cost, 0)                                  AS medicine_charge,
                ISNULL(lc.lab_cost, 0)                                  AS lab_charge,
                ROUND(ISNULL(ip.coverage_percent,0)/100.0
                    * (ISNULL(mc.med_cost,0)+ISNULL(lc.lab_cost,0)),2) AS disc
            FROM NewlyCompleted nc
            JOIN kv_Doctors d    ON d.doctor_id        = nc.doctor_id
            LEFT JOIN MedCost mc ON mc.appointment_id  = nc.appointment_id
            LEFT JOIN LabCost lc ON lc.appointment_id  = nc.appointment_id
            LEFT JOIN InsPct  ip ON ip.patient_id      = nc.patient_id
        ),
        FinalBill AS (
            SELECT
                appointment_id, patient_id, appt_date,
                consult_charge, medicine_charge, lab_charge,
                disc AS insurance_discount,
                0    AS gst_on_consult,
                ROUND(0.05 * (medicine_charge -
                    CASE WHEN (medicine_charge+lab_charge) > 0
                         THEN ROUND(disc*medicine_charge/(medicine_charge+lab_charge),2)
                         ELSE 0 END), 2) AS gst_on_medicine,
                ROUND(0.12 * (lab_charge -
                    CASE WHEN (medicine_charge+lab_charge) > 0
                         THEN ROUND(disc*lab_charge/(medicine_charge+lab_charge),2)
                         ELSE 0 END), 2) AS gst_on_lab,
                consult_charge
                + (medicine_charge + lab_charge) - disc
                + ROUND(0.05*(medicine_charge -
                    CASE WHEN (medicine_charge+lab_charge)>0
                         THEN ROUND(disc*medicine_charge/(medicine_charge+lab_charge),2)
                         ELSE 0 END),2)
                + ROUND(0.12*(lab_charge -
                    CASE WHEN (medicine_charge+lab_charge)>0
                         THEN ROUND(disc*lab_charge/(medicine_charge+lab_charge),2)
                         ELSE 0 END),2) AS payable_amount
            FROM Calculated
        )
        INSERT INTO kv_Bills (
            appointment_id, patient_id,
            consult_charge, medicine_charge, lab_charge,
            insurance_discount, gst_on_consult, gst_on_medicine, gst_on_lab,
            payable_amount, payment_status, billed_on
        )
        SELECT
            appointment_id, patient_id,
            consult_charge, medicine_charge, lab_charge,
            insurance_discount, gst_on_consult, gst_on_medicine, gst_on_lab,
            payable_amount, 'Unpaid', appt_date
        FROM FinalBill;

    END TRY
    BEGIN CATCH
        THROW;
    END CATCH;
END;
GO

-- B3: Flag Follow-Up on Abnormal Lab
CREATE OR ALTER TRIGGER dbo.trg_kv_FlagFollowUpOnAbnormalLab
ON kv_Lab_Orders
AFTER INSERT, UPDATE
AS
BEGIN
    SET NOCOUNT ON;
    IF NOT EXISTS (SELECT 1 FROM inserted WHERE is_abnormal = 1) RETURN;

    UPDATE diag
    SET    diag.requires_followup = 1
    FROM   kv_Diagnosis diag
    JOIN   inserted i ON i.appointment_id = diag.appointment_id
    WHERE  i.is_abnormal = 1;

    IF EXISTS (
        SELECT 1 FROM inserted i
        LEFT JOIN kv_Diagnosis diag ON diag.appointment_id = i.appointment_id
        WHERE i.is_abnormal = 1 AND diag.diagnosis_id IS NULL
    )
    PRINT 'WARNING: Abnormal lab result saved but no diagnosis record found. Follow-up flag not set.';
END;
GO

-- Extra B4: Bill only for Completed appointments
CREATE OR ALTER TRIGGER dbo.trg_kv_BillOnlyForCompleted
ON kv_Bills
AFTER INSERT
AS
BEGIN
    SET NOCOUNT ON;
    IF EXISTS (
        SELECT 1 FROM inserted i
        JOIN kv_Appointments a ON a.appointment_id = i.appointment_id
        WHERE a.status <> 'Completed'
    )
    BEGIN
        ROLLBACK TRANSACTION;
        THROW 50400, 'A bill can only be created for a Completed appointment.', 1;
    END;
END;
GO

-- Extra B5: Unpaid bill limit Rs. 2,00,000
CREATE OR ALTER TRIGGER dbo.trg_kv_EnforceUnpaidBillLimit
ON kv_Bills
AFTER INSERT, UPDATE
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        IF EXISTS (
            SELECT 1
            FROM (
                SELECT a.patient_id, SUM(b2.payable_amount) AS total_unpaid
                FROM inserted i
                JOIN kv_Appointments a  ON a.appointment_id = i.appointment_id
                JOIN kv_Bills        b2 ON b2.appointment_id IN (
                    SELECT b3.appointment_id
                    FROM kv_Bills b3
                    JOIN kv_Appointments a3 ON a3.appointment_id = b3.appointment_id
                    WHERE a3.patient_id = a.patient_id
                      AND b3.payment_status <> 'Paid'
                )
                GROUP BY a.patient_id
            ) u
            WHERE u.total_unpaid > 200000.00
        )
        BEGIN
            ROLLBACK TRANSACTION;
            THROW 50300, 'Patient unpaid bill limit of Rs. 2,00,000 exceeded.', 1;
        END;
    END TRY
    BEGIN CATCH THROW; END CATCH;
END;
GO

