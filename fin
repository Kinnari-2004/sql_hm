IF OBJECT_ID('dbo.fn_kv_GetPatientAge',    'FN') IS NOT NULL DROP FUNCTION dbo.fn_kv_GetPatientAge;
GO

-- Drop views
IF OBJECT_ID('dbo.vw_kv_LabOrders_ForTech',    'V') IS NOT NULL DROP VIEW dbo.vw_kv_LabOrders_ForTech;
IF OBJECT_ID('dbo.vw_kv_Patient_ForBilling',   'V') IS NOT NULL DROP VIEW dbo.vw_kv_Patient_ForBilling;
IF OBJECT_ID('dbo.vw_kv_Patient_Basic',        'V') IS NOT NULL DROP VIEW dbo.vw_kv_Patient_Basic;
GO

-- Drop tables (reverse FK order)
IF OBJECT_ID('dbo.kv_Bills',                  'U') IS NOT NULL DROP TABLE dbo.kv_Bills;
