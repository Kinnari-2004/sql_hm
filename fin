-- C2: Net Bill Verification
SELECT
    b.bill_id, b.appointment_id,
    b.payable_amount AS stored_amount,
    dbo.fn_kv_CalculateNetBill(
        b.consult_charge, b.medicine_charge,
        b.lab_charge, ISNULL(ins.coverage_percent, 0)
    ) AS function_amount,
    CASE WHEN ABS(b.payable_amount - dbo.fn_kv_CalculateNetBill(
        b.consult_charge, b.medicine_charge,
        b.lab_charge, ISNULL(ins.coverage_percent, 0))) < 1
         THEN 'Match' ELSE 'Mismatch'
    END AS verification
FROM kv_Bills b
JOIN kv_Appointments a ON a.appointment_id = b.appointment_id
LEFT JOIN kv_Patients_Insurance pi2
    ON  pi2.patient_id = a.patient_id
    AND pi2.valid_from <= a.appt_date
    AND pi2.valid_to   >= a.appt_date
LEFT JOIN kv_Insurance ins ON ins.insurance_id = pi2.insurance_id
ORDER BY b.bill_id;
