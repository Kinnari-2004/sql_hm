-- A1: Monthly Department Report
CREATE OR ALTER PROCEDURE dbo.usp_kv_MonthlyDepartmentReport
    @month INT, @year INT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        IF @month < 1 OR @month > 12
            THROW 50001, 'Invalid month. Must be 1-12.', 1;
        IF @year < 2000 OR @year > 2100
            THROW 50002, 'Invalid year. Must be 2000-2100.', 1;
        SELECT
            dep.dept_id,
            dep.dept_name                AS department_name,
            COUNT(a.appointment_id)      AS total_appointments,
            COUNT(DISTINCT a.patient_id) AS unique_patients,
            ISNULL(SUM(d.fees), 0)       AS total_consult_revenue
        FROM kv_Department dep
        LEFT JOIN kv_Doctors      d ON d.dept_id   = dep.dept_id
        LEFT JOIN kv_Appointments a ON a.doctor_id = d.doctor_id
                                   AND MONTH(a.appt_date) = @month
                                   AND YEAR(a.appt_date)  = @year
                                   AND a.status = 'Completed'
        GROUP BY dep.dept_id, dep.dept_name
        ORDER BY dep.dept_name;
    END TRY
    BEGIN CATCH THROW; END CATCH;
END;
GO

-- A2: Patient Billing Statement
CREATE OR ALTER PROCEDURE dbo.usp_kv_PatientBillingStatement
    @patient_id INT
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        IF NOT EXISTS (SELECT 1 FROM kv_Patients WHERE patient_id = @patient_id)
            THROW 50010, 'Patient ID does not exist.', 1;
        SELECT
            CASE WHEN GROUPING(a.appt_date)=1 THEN 'GRAND TOTAL'
                 ELSE CONVERT(NVARCHAR(20), a.appt_date, 106) END       AS appointment_date,
            CASE WHEN GROUPING(a.appt_date)=1 THEN '' ELSE d.doctor_name END AS doctor_name,
            SUM(b.consult_charge)                                        AS consult_charge,
            SUM(b.medicine_charge)                                       AS medicine_charge,
            SUM(b.lab_charge)                                            AS lab_charge,
            SUM(b.insurance_discount)                                    AS insurance_discount,
            SUM(b.gst_on_consult + b.gst_on_medicine + b.gst_on_lab)    AS total_gst,
            SUM(b.payable_amount)                                        AS payable_amount
        FROM kv_Appointments a
        JOIN kv_Bills   b ON b.appointment_id = a.appointment_id
        JOIN kv_Doctors d ON d.doctor_id      = a.doctor_id
        WHERE a.patient_id = @patient_id AND a.status = 'Completed'
        GROUP BY GROUPING SETS ((a.appt_date, d.doctor_name), ())
        ORDER BY GROUPING(a.appt_date), a.appt_date;
    END TRY
    BEGIN CATCH THROW; END CATCH;
END;
GO

-- A3: Doctor Performance Report
CREATE OR ALTER PROCEDURE dbo.usp_kv_DoctorPerformanceReport
    @min_appointments INT = 1
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        IF @min_appointments < 0
            THROW 50020, 'Minimum appointment count cannot be negative.', 1;
        WITH stats AS (
            SELECT d.doctor_id, d.doctor_name, dep.dept_name,
                COUNT(a.appointment_id)                                AS total_appts,
                SUM(CASE WHEN a.status='Completed' THEN 1 ELSE 0 END) AS completed_appts,
                ISNULL(SUM(b.payable_amount), 0)                       AS total_revenue,
                COUNT(DISTINCT diag.diagnosis_details)                 AS unique_diagnoses
            FROM kv_Doctors d
            JOIN kv_Department dep ON dep.dept_id = d.dept_id
            LEFT JOIN kv_Appointments a    ON a.doctor_id        = d.doctor_id
            LEFT JOIN kv_Bills        b    ON b.appointment_id   = a.appointment_id
            LEFT JOIN kv_Diagnosis    diag ON diag.appointment_id = a.appointment_id
            WHERE d.is_active = 1
            GROUP BY d.doctor_id, d.doctor_name, dep.dept_name
        )
        SELECT doctor_name,
               dept_name   AS department,
               total_appts AS total_appointments,
               completed_appts,
               CASE WHEN total_appts = 0 THEN 0.00
                    ELSE ROUND(CAST(completed_appts AS DECIMAL(10,2))/total_appts*100, 2)
               END         AS completion_rate_pct,
               total_revenue,
               unique_diagnoses
        FROM stats
        WHERE total_appts >= @min_appointments
        ORDER BY total_revenue DESC;
    END TRY
    BEGIN CATCH THROW; END CATCH;
END;
GO

-- A4: Medicines Never Prescribed
CREATE OR ALTER PROCEDURE dbo.usp_kv_MedicinesNeverPrescribed
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRY
        -- Approach 1: NOT IN
        SELECT medicine_id, medicine_name, category, price
        FROM kv_Medicines
        WHERE medicine_id NOT IN (
            SELECT DISTINCT medicine_id FROM kv_Prescription_Medicines
        );
        -- Approach 2: EXCEPT
        SELECT medicine_id, medicine_name, category, price FROM kv_Medicines
        EXCEPT
        SELECT m.medicine_id, m.medicine_name, m.category, m.price
        FROM kv_Medicines m
        JOIN kv_Prescription_Medicines pm ON pm.medicine_id = m.medicine_id;
    END TRY
    BEGIN CATCH THROW; END CATCH;
END;
GO

-- A5: Monthly Revenue vs Target
CREATE OR ALTER PROCEDURE dbo.usp_kv_MonthlyRevenueVsTarget
AS
BEGIN
    SET NOCOUNT ON;
    DECLARE @target DECIMAL(12,2) = 500000.00;
    BEGIN TRY
        WITH monthly AS (
            SELECT YEAR(billed_on)      AS bill_year,
                   MONTH(billed_on)     AS bill_month,
                   SUM(payable_amount)  AS total_revenue
            FROM kv_Bills
            GROUP BY YEAR(billed_on), MONTH(billed_on)
        )
        SELECT
            FORMAT(DATEFROMPARTS(bill_year, bill_month, 1), 'MMM yyyy') AS month_year,
            total_revenue,
            CASE WHEN total_revenue >= @target THEN 'Yes' ELSE 'No' END AS target_met,
            total_revenue - @target                                      AS surplus_or_deficit
        FROM monthly
        ORDER BY bill_year, bill_month;

        SELECT
            SUM(CASE WHEN total_revenue >= @target THEN 1 ELSE 0 END) AS months_met,
            SUM(CASE WHEN total_revenue <  @target THEN 1 ELSE 0 END) AS months_not_met
        FROM (
            SELECT YEAR(billed_on) y, MONTH(billed_on) m,
                   SUM(payable_amount) total_revenue
            FROM kv_Bills
            GROUP BY YEAR(billed_on), MONTH(billed_on)
        ) sub;
    END TRY
    BEGIN CATCH THROW; END CATCH;
END;
GO

