-- ============================================================
-- SECTION 03B — kv_Bills DATA (calculated with GST + insurance)
-- GST: 0% consult | 5% medicine | 12% lab
-- Insurance discount applied on med+lab only, before GST
-- ============================================================
INSERT INTO kv_Bills (
    appointment_id, patient_id,
    consult_charge, medicine_charge, lab_charge,
    insurance_discount, gst_on_consult, gst_on_medicine, gst_on_lab,
    payable_amount, payment_status, billed_on
)
SELECT
    a.appointment_id,
    a.patient_id,
    d.fees                                                              AS consult_charge,
    ISNULL(med.med_cost, 0)                                             AS medicine_charge,
    ISNULL(lab.lab_cost, 0)                                             AS lab_charge,
    ROUND(ISNULL(ins.coverage_percent,0)/100.0
          * (ISNULL(med.med_cost,0) + ISNULL(lab.lab_cost,0)), 2)      AS insurance_discount,
    0                                                                   AS gst_on_consult,
    ROUND(0.05 * (ISNULL(med.med_cost,0)
        - CASE WHEN (ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0)) > 0
               THEN ROUND(ISNULL(ins.coverage_percent,0)/100.0
                    * (ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0)),2)
                    * ISNULL(med.med_cost,0)
                    / (ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0))
               ELSE 0 END), 2)                                          AS gst_on_medicine,
    ROUND(0.12 * (ISNULL(lab.lab_cost,0)
        - CASE WHEN (ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0)) > 0
               THEN ROUND(ISNULL(ins.coverage_percent,0)/100.0
                    * (ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0)),2)
                    * ISNULL(lab.lab_cost,0)
                    / (ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0))
               ELSE 0 END), 2)                                          AS gst_on_lab,
    d.fees
    + (ISNULL(med.med_cost,0) + ISNULL(lab.lab_cost,0))
    - ROUND(ISNULL(ins.coverage_percent,0)/100.0
            * (ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0)), 2)
    + ROUND(0.05*(ISNULL(med.med_cost,0)
        - CASE WHEN (ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0))>0
               THEN ROUND(ISNULL(ins.coverage_percent,0)/100.0
                    *(ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0)),2)
                    *ISNULL(med.med_cost,0)/(ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0))
               ELSE 0 END),2)
    + ROUND(0.12*(ISNULL(lab.lab_cost,0)
        - CASE WHEN (ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0))>0
               THEN ROUND(ISNULL(ins.coverage_percent,0)/100.0
                    *(ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0)),2)
                    *ISNULL(lab.lab_cost,0)/(ISNULL(med.med_cost,0)+ISNULL(lab.lab_cost,0))
               ELSE 0 END),2)                                           AS payable_amount,
    CASE a.appointment_id % 3
        WHEN 0 THEN 'Paid'
        WHEN 1 THEN 'Unpaid'
        ELSE        'Partially Paid'
    END                                                                 AS payment_status,
    a.appt_date                                                         AS billed_on
FROM kv_Appointments a
JOIN kv_Doctors d ON d.doctor_id = a.doctor_id
LEFT JOIN (
    SELECT pr.appointment_id, SUM(m.price * pm.quantity) AS med_cost
    FROM   kv_Prescriptions pr
    JOIN   kv_Prescription_Medicines pm ON pm.prescription_id = pr.prescription_id
    JOIN   kv_Medicines m               ON m.medicine_id      = pm.medicine_id
    GROUP  BY pr.appointment_id
) med ON med.appointment_id = a.appointment_id
LEFT JOIN (
    SELECT lo.appointment_id, SUM(lt.price) AS lab_cost
    FROM   kv_Lab_Orders lo
    JOIN   kv_Lab_Tests  lt ON lt.lab_test_id = lo.lab_test_id
    GROUP  BY lo.appointment_id
) lab ON lab.appointment_id = a.appointment_id
LEFT JOIN kv_Patients_Insurance pi2
    ON  pi2.patient_id = a.patient_id
    AND pi2.valid_from <= a.appt_date
    AND pi2.valid_to   >= a.appt_date
LEFT JOIN kv_Insurance ins ON ins.insurance_id = pi2.insurance_id
WHERE a.status = 'Completed';
GO

