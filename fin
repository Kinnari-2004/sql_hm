IF OBJECT_ID('dbo.kv_Medicines',              'U') IS NOT NULL DROP TABLE dbo.kv_Medicines;
IF OBJECT_ID('dbo.kv_Diagnosis',              'U') IS NOT NULL DROP TABLE dbo.kv_Diagnosis;
IF OBJECT_ID('dbo.kv_Appointments',           'U') IS NOT NULL DROP TABLE dbo.kv_Appointments;
